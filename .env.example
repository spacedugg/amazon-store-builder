# Anthropic API key for Claude AI (store generation)
VITE_ANTHROPIC_API_KEY=sk-ant-xxxxx

# Bright Data API key for Amazon product scraping
BRIGHT_DATA_API_KEY=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Google Gemini API key for image analysis (Vision)
GEMINI_API_KEY=AIzaSy-xxxxx

# Turso database (added via Vercel integration)
TURSO_DATABASE_URL=libsql://your-db.turso.io
TURSO_AUTH_TOKEN=your-auth-token

# Oeffentliche Basis URL fuer geteilte Links (Designer Briefing + Customer
# Preview). Optional. Ohne diese Variable wird die fest hinterlegte Custom
# Domain benutzt. Niemals die geschuetzte *.vercel.app URL eintragen, sonst
# erzwingen geteilte Links ein Vercel Login.
VITE_SHARE_BASE_URL=https://brand-store-preview.temoa.de
